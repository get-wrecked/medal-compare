---
interface Props {
  verdict: string;
}

const { verdict } = Astro.props;
---

<section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pt-1 pb-2">
  <div class="rounded-xl border border-medal-primary/20 bg-medal-primary/5 p-6 sm:p-8">
    <h2 class="text-lg sm:text-xl font-bold font-mono mb-3">TL;DR</h2>
    <p class="text-base text-medal-text-muted leading-relaxed">{verdict}</p>
  </div>
</section>
