---
import type { FAQItem } from '../data/comparisons';

interface Props {
  faqs: FAQItem[];
}

const { faqs } = Astro.props;
---

<section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
  <h2 class="text-xl sm:text-2xl font-bold font-mono mb-8">
    Other Frequently Asked Questions
  </h2>

  <div class="space-y-3">
    {faqs.map((faq) => (
      <details class="group rounded-xl border border-medal-border bg-medal-surface overflow-hidden">
        <summary class="flex items-center justify-between px-6 py-4 hover:bg-medal-surface-light transition-colors">
          <h3 class="text-base font-medium text-medal-text pr-4">{faq.question}</h3>
          <svg class="chevron w-5 h-5 text-medal-text-muted shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-6 pb-5">
          <p class="text-medal-text-muted leading-relaxed [&_a]:text-medal-primary [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:text-medal-primary-dark" set:html={faq.answer}></p>
        </div>
      </details>
    ))}
  </div>
</section>
