---
import { allComparisons } from '../data/comparisons';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;

const otherPages = allComparisons.filter((c) => c.slug !== currentSlug);
---

<section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
  <!-- More Comparisons -->
  <div>
    <h2 class="text-lg font-bold font-mono mb-4">More Like This</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
      {otherPages.map((page) => (
        <a
          href={`/${page.slug}/`}
          class="group flex items-center gap-1.5 px-4 py-2.5 rounded-lg border border-medal-border bg-medal-surface hover:bg-medal-surface-light hover:border-medal-primary/30 transition-all text-sm whitespace-nowrap"
        >
          <span class="text-medal-primary font-medium">Medal</span>
          <span class="text-medal-text-muted">Vs.</span>
          <span class="text-medal-text-muted group-hover:text-medal-text transition-colors">{page.competitorShort}</span>
          <svg class="w-4 h-4 text-medal-text-faint group-hover:text-medal-primary shrink-0 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>
