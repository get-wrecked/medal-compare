---
interface Props {
  competitor: string;
  subtitle: string;
  competitorUrl: string;
  heroImage?: string;
}

const { competitor, subtitle, competitorUrl, heroImage } = Astro.props;
const bannerSrc = heroImage || '/images/hero-banner.png';
---

<section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 sm:pt-16 pb-4 sm:pb-6">
  <!-- Hero image -->
  <div class="mb-8 rounded-xl overflow-hidden border border-medal-border">
    <img src={bannerSrc} alt={`Medal vs ${competitor}`} class="w-full" loading="eager" />
  </div>

  <p class="text-sm text-medal-text-subtle uppercase tracking-wider font-medium mb-4">Comparison</p>

  <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold font-mono leading-tight">
    <span class="text-medal-primary">Medal</span>
    <span class="text-medal-text-muted font-normal"> vs. </span>
    <span class="text-medal-text">{competitor}</span>
  </h1>

  <p class="mt-5 text-lg text-medal-text-muted leading-relaxed">
    {subtitle}
  </p>

  <!-- Divider -->
  <div class="mt-5 border-b border-medal-border"></div>
</section>
