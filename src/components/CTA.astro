---

<section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-14 sm:py-20">
  <div class="relative rounded-2xl border border-medal-border bg-medal-surface overflow-hidden">
    <!-- Background glow -->
    <div class="absolute inset-0 bg-gradient-to-br from-medal-primary/5 via-transparent to-transparent pointer-events-none"></div>

    <div class="relative flex flex-col md:flex-row items-center gap-6 p-8 sm:p-10">
      <div class="flex-1 text-center md:text-left">
        <h2 class="text-3xl sm:text-4xl font-bold mb-8 font-mono">
          9 out of 10 PC gamers already use Medal
        </h2>
        <a
          href="https://medal.tv/download"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-10 py-4 bg-medal-primary hover:bg-medal-primary-dark text-black font-semibold rounded-xl transition-colors text-lg shadow-lg shadow-medal-primary/25"
        >
          Join Today
        </a>
      </div>
      <div class="flex-1">
        <img
          src="/images/medal-cta-image.png"
          alt="Medal game clipping app"
          class="w-full rounded-xl"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
